{
  "title": "Diet Log",
  "description": "Yazio nutrition analysis fields",
  "type": "object",
  "properties": {
    "date": { "type": "string", "description": "YYYY-MM-DD" },
    "energy_kcal_consumed": { "type": "number" },
    "energy_kcal_goal": { "type": "number" },
    "protein_g_consumed": { "type": "number" },
    "protein_g_goal": { "type": "number" },
    "carb_g_consumed": { "type": "number" },
    "carb_g_goal": { "type": "number" },
    "fat_g_consumed": { "type": "number" },
    "fat_g_goal": { "type": "number" },
    "water_ml_consumed": { "type": "number" },
    "water_ml_goal": { "type": "number" },
    "steps": { "type": "number" },
    "meal_distribution": {
      "type": "object",
      "properties": {
        "breakfast_pct": { "type": "number" },
        "lunch_pct": { "type": "number" },
        "dinner_pct": { "type": "number" },
        "snack_pct": { "type": "number" }
      }
    },
    "calorie_adherence_pct": { "type": "number" },
    "protein_adherence_pct": { "type": "number" },
    "carb_adherence_pct": { "type": "number" },
    "fat_adherence_pct": { "type": "number" },
    "water_adherence_pct": { "type": "number" },
    "is_logging_day": { "type": "boolean" },
    "logging_streak_proxy_days": { "type": "integer" },
    "risk_flags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    }
  }
}
