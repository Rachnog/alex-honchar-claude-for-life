{
  "title": "Journal Entry",
  "description": "Transcribed handwritten journal entry from reMarkable",
  "type": "object",
  "properties": {
    "date": { "type": "string", "format": "date" },
    "source_notebook": { "type": "string" },
    "source_page": { "type": "integer" },
    "transcription_ru": { "type": "string", "description": "Russian transcription" },
    "summary_en": { "type": "string", "description": "English summary, 1-2 sentences" },
    "sentiment": { "type": "integer", "minimum": 1, "maximum": 5 },
    "themes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["stress", "health", "sleep", "exercise", "identity",
                 "relationships", "work", "travel", "overeating", "pain",
                 "anxiety", "productivity", "spirituality", "anger",
                 "jealousy", "gratitude"]
      }
    }
  }
}
